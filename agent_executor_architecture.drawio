          <mxGeometry x="40" y="530" width="1060" height="80" as="geometry" />
        </mxCell>

        <!-- Nodes in lanes -->
        <!-- Caller -->
        <mxCell id="lc-req" value="Request&lt;br/&gt;(JSON/SSE/Queue)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A3A5C;strokeColor=#1A3A5C;fontColor=#FFFFFF;fontSize=11;" vertex="1" parent="lane-caller">
          <mxGeometry x="40" y="25" width="130" height="40" as="geometry" />
