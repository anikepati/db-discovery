        <mxCell id="lc-resp" value="Response&lt;br/&gt;(stream / sync)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A3A5C;strokeColor=#1A3A5C;fontColor=#FFFFFF;fontSize=11;" vertex="1" parent="lane-caller">
